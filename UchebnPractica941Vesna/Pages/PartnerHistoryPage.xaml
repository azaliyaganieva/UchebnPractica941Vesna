<Page x:Class="UchebnPractica941Vesna.Pages.PartnerHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="PartnerHistoryPage"
      FontFamily="Candara"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

       
        <Border Background="#D2DFFF" Grid.Row="0" Padding="10">
            <TextBlock Text="История продаж партнера" FontSize="20" FontWeight="Bold" 
                       Foreground="#355CBD" HorizontalAlignment="Center"/>
        </Border>

       
        <Border Background="White" Grid.Row="1" Margin="20" Padding="15" BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Партнер:" FontWeight="Bold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PartnerNameTb"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Директор:" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DirectorTb"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Скидка:" FontWeight="Bold"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DiscountTb" Foreground="#355CBD" FontWeight="Bold"/>
            </Grid>
        </Border>

           <Border Grid.Row="2" Margin="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Реализованная продукция" FontSize="14" FontWeight="Bold" 
                           Foreground="#355CBD" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="SalesListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Дата" Width="100" 
                                                DisplayMemberBinding="{Binding SaleDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                                <GridViewColumn Header="Продукция" Width="250" 
                                                DisplayMemberBinding="{Binding ProductName}"/>
                                <GridViewColumn Header="Кол-во" Width="80" 
                                                DisplayMemberBinding="{Binding Quantity}"/>
                                <GridViewColumn Header="Сумма" Width="100" 
                                                DisplayMemberBinding="{Binding Amount, StringFormat={}{0:N0} ₽}"/>
                                <GridViewColumn Header="Точка продажи" Width="150" 
                                                DisplayMemberBinding="{Binding SalePointName}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>

                <TextBlock x:Name="EmptyMessage" Grid.Row="1" Text="Нет данных о продажах" 
                           Foreground="Gray" HorizontalAlignment="Center" 
                           VerticalAlignment="Center" Visibility="Collapsed"/>
            </Grid>
        </Border>

   
        <Button Grid.Row="3" x:Name="BackBtn" Click="BackBtn_Click" 
                Background="#355CBD" Foreground="White" 
                Content="Назад" FontSize="14" Width="100" Height="35"
                HorizontalAlignment="Center" Margin="20"/>
    </Grid>
</Page>