<Page x:Class="UchebnPractica941Vesna.Pages.AddEditPartners"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchebnPractica941Vesna.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="AddEditPartners">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Наименование</TextBlock>
                <TextBox Text="{Binding NamePartner}" Width="300" Margin="3"></TextBox>
            </StackPanel>
        

        
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Тип</TextBlock>
                <ComboBox x:Name="TypeCmb" SelectedItem="{Binding TypeOfBusiness}" Width="300" Margin="3"></ComboBox>
            </StackPanel>
       

        
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Юридический адрес</TextBlock>
                <TextBox Text="{Binding UrAdress}" Width="300" Margin="3"></TextBox>
            </StackPanel>
       

        
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>ИНН</TextBlock>
                <TextBox Text="{Binding INN}" Width="300" Margin="3"></TextBox>
            </StackPanel>
        

       
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Фамилия директора</TextBlock>
                <TextBox Text="{Binding SurnameDirector}" Width="300" Margin="3"></TextBox>
            </StackPanel>



            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Имя директора</TextBlock>
                <TextBox Text="{Binding NameDirector}" Width="300" Margin="3"></TextBox>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Отчество директора</TextBlock>
                <TextBox Text="{Binding PatronumicDirector}" Width="300" Margin="3"></TextBox>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Телефон</TextBlock>
                <TextBox Text="{Binding Phone}" Width="300" Margin="3"></TextBox>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Почта</TextBlock>
                <TextBox Text="{Binding Email}" Width="300" Margin="3"></TextBox>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock>Рейтинг</TextBlock>
                <TextBox Text="{Binding Raiting}" Width="300" Margin="3"></TextBox>
            </StackPanel>

            <StackPanel  Orientation="Horizontal">
                <Button x:Name="SaveBtn" Click="SaveBtn_Click">Сохранить</Button>
                <Button x:Name="OtmenaBtn" Click="OtmenaBtn_Click">Отмена</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
