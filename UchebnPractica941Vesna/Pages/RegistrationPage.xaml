<Page x:Class="UchebnPractica941Vesna.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" d:DesignWidth="1000"
      Title="RegistrationPage"
      ScrollViewer.VerticalScrollBarVisibility="Auto" Height="1306">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <TextBlock Text="Регистрация нового пользователя" Grid.Row="0" Grid.Column="1" 
                       FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" 
                       Margin="0,30,0,20" Foreground="#355CBD"/>


            <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,10" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Личные данные" FontSize="15" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="#355CBD"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="SurnameBox" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="PatronumicBox" Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center" Margin="0,5"/>
                        <DatePicker x:Name="BirthdayPicker" Grid.Row="3" Grid.Column="1" Margin="46,5,0,5"/>
                    </Grid>
                </StackPanel>
            </Border>


            <Border Grid.Row="2" Grid.Column="1" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,10" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Паспортные данные" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="#355CBD"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Text="Серия паспорта:" VerticalAlignment="Center" Margin="0,0,306,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="PassportSeriaBox" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="8" MaxLength="4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Номер паспорта:" VerticalAlignment="Center" Margin="0,0,302,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="PassportNumberBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="8" MaxLength="6"/>
                    </Grid>
                </StackPanel>
            </Border>


            <Border Grid.Row="3" Grid.Column="1" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,10" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Банковские реквизиты" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="#355CBD"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Банковские реквизиты:" VerticalAlignment="Center" Margin="0,0,268,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="BankDetailsBox" Grid.Column="1" Margin="89,5,69,5" Padding="8"/>
                    </Grid>
                </StackPanel>
            </Border>


            <Border Grid.Row="4" Grid.Column="1" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,10" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Дополнительная информация" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="#355CBD"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Text="Семейное положение:" VerticalAlignment="Center" Margin="0,0,272,0" Grid.ColumnSpan="2"/>
                        <ComboBox x:Name="FamilyStatusCmb" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Состояние здоровья:" VerticalAlignment="Center" Margin="0,0,275,0" Grid.ColumnSpan="2"/>
                        <ComboBox x:Name="HealthCmb" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:" VerticalAlignment="Center" Margin="0,5"/>
                        <ComboBox x:Name="RoleCmb" Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="8"/>
                    </Grid>
                </StackPanel>
            </Border>


            <Border Grid.Row="5" Grid.Column="1" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,20" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Данные для входа" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="#355CBD"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="LoginBox" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" VerticalAlignment="Center" Margin="0,5"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="1" Margin="69,5,69,5" Padding="8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Подтверждение пароля:" VerticalAlignment="Center" Margin="0,5"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="2" Grid.Column="1" Margin="69,5,69,5" Padding="8"/>
                    </Grid>
                </StackPanel>
            </Border>


            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="0,0,0,30">
                <Button x:Name="RegisterBtn" Click="RegisterBtn_Click" 
                        Background="#355CBD" Foreground="White" 
                        Content="Зарегистрироваться" FontSize="16" 
                        Width="200" Height="40" Margin="5"/>
                <Button x:Name="CancelBtn" Click="CancelBtn_Click" 
                        Background="White" Foreground="#355CBD" 
                        Content="Отмена" FontSize="16" 
                        Width="100" Height="40" Margin="5"
                        BorderBrush="#355CBD" BorderThickness="1"/>
            </StackPanel>


            <TextBlock x:Name="ErrorText" Grid.Row="7" Grid.Column="1" 
                       Foreground="Red" TextWrapping="Wrap" 
                       HorizontalAlignment="Center" Margin="0,10"/>
        </Grid>
    </ScrollViewer>
</Page>